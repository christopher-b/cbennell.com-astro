{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*"
	],
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		"strictNullChecks": true,
		"paths": {
			"@src/*": [
				"./src/*"
			],
			"@components/*": [
				"./src/components/*"
			],
			"@assets/*": [
				"./src/assets/*"
			],
			"@styles/*": [
				"./src/styles/*"
			]
		}
	}
}
