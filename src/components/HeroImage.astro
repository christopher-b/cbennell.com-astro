---
import { Image } from 'astro:assets';
import { getCoverImage } from '@lib/images';

interface Props {
  filename: string | undefined;
  alt?: string;
}

const { filename, alt = '' } = Astro.props;
const src = await getCoverImage(filename);
---

{src && (
  <picture feature>
    <Image src={src} alt={alt} />
  </picture>
)}
