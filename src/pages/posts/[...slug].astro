---
import { render } from 'astro:content';
import { getCoverImage } from '@lib/images';
import { getPublishedPosts } from '@lib/posts';

import DefaultLayout from '@layouts/Default.astro';
import PostMeta from '@components/PostMeta.astro'
import TagList from '@components/TagList.astro'
import NextPrevPost from '@components/NextPrevPost.astro';
import HeroImage from '@components/HeroImage.astro';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
	return posts.filter((post) => !post.data.link).map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
const { title, description, heroImage, tags, section } = post.data;
const coverImage = await getCoverImage(heroImage, title);
---

<DefaultLayout
  title={title}
  description={description ?? ''}
  image={coverImage}
>
  <article class="post">
    <header>
      <h1>{title}</h1>
      <PostMeta post={post} />
      {tags && <TagList tags={tags} /> }
      <HeroImage image={coverImage} />
    </header>

    <content>
      <Content />
    </content>

    {section == "post" &&
      <footer>
        <NextPrevPost />
      </footer>
    }
  </article>
</DefaultLayout>
