---
import { render } from 'astro:content';
import { getPage } from '@src/lib/pages';
import DefaultLayout from '@layouts/Default.astro';
import HeroImage from '@components/HeroImage.astro';

const page = await getPage('About Christopher');
const { Content } = await render(page);
const { title, heroImage } = page.data;
---

<DefaultLayout>
  <article class="post">
    <header>
      <h1>{title}</h1>
      <HeroImage filename={heroImage} />
    </header>

    <content>
      <Content />
    </content>
  </article>
</DefaultLayout>


